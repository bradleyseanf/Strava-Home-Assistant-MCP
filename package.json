{
  "name": "strava-home-assistant-mcp",
  "version": "0.1.0",
  "description": "Local/on-prem MCP server for Strava activity data stored in a Home Assistant SQLite database",
  "main": "dist/server.js",
  "bin": {
    "strava-home-assistant-mcp": "./dist/server.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "strava",
    "sqlite",
    "home-assistant",
    "local"
  ],
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.3.0",
    "express": "^4.21.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.7"
  }
}
